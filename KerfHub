local alertRemote = game:GetService("ReplicatedStorage").Remotes.Alert

local getConns = getconnections or syn and syn.getconnections
if getConns then
    for _, conn in ipairs(getConns(alertRemote.OnClientEvent)) do
        conn:Disable()
    end
end

alertRemote.OnClientEvent:Connect(function(...)
    local args = {...}

    -- block the standard alert payload
    if args[1] == "Preset" and args[2] == "ERROR" then
        local msg = args[3]
        if msg == "Out of stock" or msg == "NoCash" then
            return
        end
    end

    -- block the raw result payload
    if args[1] == false and args[2] == "NoCash" then
        return
    end

    -- allow other alerts if needed
    warn("Alert:", unpack(args))
end)

end

