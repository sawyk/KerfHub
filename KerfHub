local FarmTab = Window:CreateTab("Farm", 4483362458) -- Title, Image

local Section = FarmTab:CreateSection("Auto Farm")

local SellWheat = game:GetService("ReplicatedStorage").Remotes.Sell
local RunSell = false
local MinimumPrice = 5
local SellToggle = FarmTab:CreateToggle({
    Name = "Sell Wheat",
    CurrentValue = false,
    Flag = "SellWheat",
    Callback = function(Value)
        RunSell = Value
        if Value then
            task.spawn(function()
                while RunSell do
                    -- Get current price from the Sell UI
                    local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
                    local UI = PlayerGui:FindFirstChild("UI")
                    local currentPrice = 0
                    
                    if UI then
                        local sellPage = UI:FindFirstChild("Pages") and UI.Pages:FindFirstChild("Sell")
                        if sellPage then
                            local main = sellPage:FindFirstChild("Main")
                            if main then
                                local currentPriceLabel = main:FindFirstChild("CurrentPrice")
                                if currentPriceLabel then
                                    local priceText = currentPriceLabel:FindFirstChild("Price")
                                    if priceText then
                                        -- Extract number from "Current Price: $X" text
                                        local text = priceText.Text
                                        local price = tonumber(text:match("%$([0-9]+)")) or 0
                                        currentPrice = price
                                    end
                                end
                            end
                        end
                    end
                    
                    -- Only sell if current price meets or exceeds minimum
                    if currentPrice >= MinimumPrice then
                        SellWheat:FireServer()
                    end
                    task.wait(0.1)
                end
            end)
        end
    end,
})

