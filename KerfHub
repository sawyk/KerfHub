-- ✅ FIX #12: SAFE REMOTE WRAPPERS (handle nil remotes)
local function SafeFire(remote, ...)
    if not remote then return end
    local args = {...}
    pcall(function()
        remote:FireServer(unpack(args))
    end)
end

local function SafeInvoke(remote, ...)
    if not remote then return end
    local args = {...}
    local success, result = pcall(function()
        return remote:InvokeServer(unpack(args))
    end)
    return success, result
end

-- ✅ FIX #7: LOOP MANAGEMENT (prevents duplicate threads)
local ActiveLoops = {}

local function StartLoop(name, fn, interval)
    if ActiveLoops[name] then return end
    
    ActiveLoops[name] = true
    
    task.spawn(function()
        while ActiveLoops[name] do
            fn()
            task.wait(interval or 0.1)
        end
    end)
end

local function StopLoop(name)
    ActiveLoops[name] = nil
end

-- ✅ FIX #16: UNIVERSAL TOGGLE TEMPLATE (eliminates duplicate code)
local function CreateLoopToggle(tab, name, flag, interval, callback)
    local running = false

    tab:CreateToggle({
        Name = name,
        CurrentValue = false,
        Flag = flag,
        Callback = function(v)
            running = v

            if v then
                task.spawn(function()
                    while running do
                        callback()
                        task.wait(interval or 0.1)
                    end
                end)
            end
        end,
    })

    return function() return running end
end

