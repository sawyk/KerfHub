-- ✅ SAFE REMOTE LOADER (prevents errors if remote doesn't exist)
local function GetRemote(path)
    local obj = RS
    for part in path:gmatch("[^.]+") do
        if obj then
            obj = obj:FindFirstChild(part)
        else
            return nil
        end
    end
    return obj
end

-- ✅ FIX #2: CHARACTER HELPERS (respawn-safe)
