local function FixDropper(dropper)
    pcall(function()
        if not dropper then return end

        local union = dropper:FindFirstChildWhichIsA("UnionOperation", true)

        -- If the UnionOperation spawned outside the model
        if not union then
            local possibleUnion = BuildingParts:FindFirstChild("Dropper")

            if possibleUnion and possibleUnion:IsA("UnionOperation") then
                union = possibleUnion
            end
        end

        if union then
            -- Match manually placed dropper properties
            union.Anchored = true
            union.CollisionGroup = "Dropper"

            union.AssemblyLinearVelocity = Vector3.zero
            union.AssemblyAngularVelocity = Vector3.zero

            -- Try to stop physics ownership issues
            pcall(function()
                union:SetNetworkOwner(game.Players.LocalPlayer)
            end)

            -- Put UnionOperation inside the Dropper model
            if union.Parent ~= dropper then
                union.Parent = dropper
            end
        end
    end)
end


