-- ✅ ANOMALY DETECTION SYSTEM
local DetectedSkinwalkers = {}
local DetectionRunning = false

-- Helper function to check if NPC is a skinwalker
local function IsSkinwalker(npc)
    if not npc or not npc:FindFirstChildOfClass("Humanoid") then
        return false
    end
    
    -- ✅ MAIN DETECTION: Check for Skinwalker attribute
    if npc:GetAttribute("Skinwalker") then
        return true
    end
    
    -- Backup detection: Check for anomaly effects
    if npc:GetAttribute("PhotoEffect") then
        return true
    end
    
    if npc:GetAttribute("CameraEffect") then
        return true
    end
    
    return false
end

-- Highlight function
local function HighlightNPC(npc)
    if not npc or DetectedSkinwalkers[npc] then return end
    
    DetectedSkinwalkers[npc] = true
    
    -- Create highlight with white outline and 75% transparent red fill
    if not npc:FindFirstChild("SkinwalkerHighlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "SkinwalkerHighlight"
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red
        highlight.FillTransparency = 0.75 -- 75% transparent
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White outline
        highlight.OutlineTransparency = 0 -- Fully opaque outline
        highlight.Parent = npc
    end
end

-- Remove highlight function
local function RemoveHighlight(npc)
    if not npc then return end
    
    DetectedSkinwalkers[npc] = nil
    
    -- Remove highlight
    local highlight = npc:FindFirstChild("SkinwalkerHighlight")
    if highlight then
        highlight:Destroy()
    end
end

-- Scan all NPCs
local function ScanAllNPCs()
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return end
    
    for _, npc in ipairs(npcsFolder:GetChildren()) do
        if IsSkinwalker(npc) then
            HighlightNPC(npc)
        else
            RemoveHighlight(npc)
        end
    end
end

