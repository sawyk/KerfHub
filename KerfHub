    local function getEnemyPositions()
        local positions = {}

        for _, enemy in ipairs(workspace.Entities.Enemy:GetChildren()) do
            if enemy:IsA("Model") then
                local part = enemy.PrimaryPart or enemy:FindFirstChildWhichIsA("BasePart")

                if part then
                    table.insert(positions, part.Position + Vector3.new(0, 5, 0))
